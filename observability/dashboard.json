{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Request rate by HTTP status",
      "type": "timeseries",
      "targets": [
        {"expr": "sum by (status_code) (rate(http_requests_total{service=\"order-service\"}[5m]))", "legendFormat": "{{status_code}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "5xx error rate",
      "type": "timeseries",
      "targets": [
        {"expr": "100 * sum(rate(http_requests_total{service=\"order-service\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"order-service\"}[5m])), 0.001)", "legendFormat": "5xx %", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "Request latency percentiles",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"order-service\"}[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"order-service\"}[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"order-service\"}[5m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "id": 4,
      "title": "Available replicas",
      "type": "timeseries",
      "targets": [
        {"expr": "kube_deployment_status_replicas_available{namespace=\"order-service\",deployment=\"order-service\"}", "legendFormat": "available", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8}
    },
    {
      "id": 5,
      "title": "Error budget remaining",
      "type": "gauge",
      "targets": [
        {"expr": "100 * order_service:error_budget_remaining:ratio_30d", "legendFormat": "remaining", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 10}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["order-service", "sre"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Order Service SRE",
  "uid": "order-service-sre",
  "version": 1
}
